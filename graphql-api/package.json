{
	"name": "graphql-api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "dotenv -e .env.development -- wrangler dev",
		"db:migrate:dev": "dotenv -e .env.development -- drizzle-kit migrate",
		"db:migrate:prod": "drizzle-kit migrate",
		"db:studio": "dotenv -e .env.development -- drizzle-kit studio",
		"test": "vitest",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.18.4",
		"@eddeee888/gcg-typescript-resolver-files": "^0.17.0",
		"@graphql-codegen/cli": "^7.2.0",
		"@types/node": "^26.1.1",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.5.2",
		"vitest": "^4.1.0",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"graphql": "^16.14.2",
		"graphql-scalars": "^1.25.0",
		"graphql-yoga": "^5.21.2",
		"postgres": "^3.4.9"
	}
}
